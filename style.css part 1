                                                                                                                                                                                                      
  * {                                                                                                                                                                                                  
      margin: 0;                                                                                                                                                                                       
      padding: 0;                                                                                                                                                                                      
      box-sizing: border-box;                                                                                                                                                                          
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  body {                                                                                                                                                                                               
      font-family: 'Inter', sans-serif;                                                                                                                                                              
      line-height: 1.6;                                                                                                                                                                                
      background-color: #f8fafc;                                                                                                                                                                       
      color: #1e293b;                                                                                                                                                                                  
      min-height: 100vh;                                                                                                                                                                               
      scroll-behavior: smooth;                                                                                                                                                                         
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  a {                                                                                                                                                                                                  
      color: #1e40af;                                                                                                                                                                                  
      text-decoration: none;                                                                                                                                                                           
      transition: color 0.3s ease;                                                                                                                                                                   
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  a:hover {                                                                                                                                                                                            
      color: #334155;                                                                                                                                                                                  
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .container {                                                                                                                                                                                         
      width: 100%;                                                                                                                                                                                     
      max-width: 1200px;                                                                                                                                                                               
      margin: 0 auto;                                                                                                                                                                                  
      padding: 0 2rem;                                                                                                                                                                                 
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  h1, h2, h3 {                                                                                                                                                                                         
      font-weight: 700;                                                                                                                                                                                
      line-height: 1.2;                                                                                                                                                                                
      color: #111827;                                                                                                                                                                                  
      margin-bottom: 1rem;                                                                                                                                                                             
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  h1 { font-size: 3rem; text-align: center; }                                                                                                                                                          
  h2 { font-size: 2rem; margin-bottom: 1.5rem; text-align: center; }                                                                                                                                 
  h3 { font-size: 1.5rem; color: #334155; margin-bottom: 0.75rem; }                                                                                                                                    
  p { margin-bottom: 1rem; font-size: 1.1rem; }                                                                                                                                                        
  ul { list-style: none; }                                                                                                                                                                             
                                                                                                                                                                                                       
  :root {                                                                                                                                                                                              
      --primary: #1f2937;                                                                                                                                                                              
      --primary-500: #111827;                                                                                                                                                                          
      --secondary: #64748b;                                                                                                                                                                            
      --accent: #6366f1;                                                                                                                                                                               
      --success: #84cc16;                                                                                                                                                                              
      --danger: #e53e3e;                                                                                                                                                                               
      --gray: #e5e7eb;                                                                                                                                                                                 
      --white: #f8fafc;                                                                                                                                                                                
      --black: #111827;                                                                                                                                                                                
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  header {                                                                                                                                                                                             
      background-color: var(--white);                                                                                                                                                                  
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);                                                                                                                                                           
      position: sticky;                                                                                                                                                                                
      top: 0;                                                                                                                                                                                          
      z-index: 100;                                                                                                                                                                                    
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-container {                                                                                                                                                                                     
      display: flex;                                                                                                                                                                                   
      justify-content: space-between;                                                                                                                                                                  
      align-items: center;                                                                                                                                                                             
      padding: 1rem 0;                                                                                                                                                                                 
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-logo {                                                                                                                                                                                          
      display: flex;                                                                                                                                                                                 
      align-items: center;                                                                                                                                                                             
      gap: 0.75rem;                                                                                                                                                                                    
      font-weight: 600;                                                                                                                                                                                
      font-size: 1.25rem;                                                                                                                                                                              
      color: var(--primary-500);                                                                                                                                                                       
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-menu {                                                                                                                                                                                          
      display: flex;                                                                                                                                                                                 
      align-items: center;                                                                                                                                                                             
      gap: 1.5rem;                                                                                                                                                                                     
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-link {                                                                                                                                                                                          
      font-weight: 500;                                                                                                                                                                                
      color: var(--secondary);                                                                                                                                                                         
      transition: color 0.3s ease;                                                                                                                                                                     
      padding: 0.5rem 1rem;                                                                                                                                                                            
      border-radius: 0.375rem;                                                                                                                                                                         
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-link.active {                                                                                                                                                                                   
      color: var(--primary-500);                                                                                                                                                                     
      font-weight: 600;                                                                                                                                                                                
      background-color: #f0f4ff;                                                                                                                                                                       
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-toggle {                                                                                                                                                                                        
      display: none;                                                                                                                                                                                   
      flex-direction: column;                                                                                                                                                                          
      gap: 0.5rem;                                                                                                                                                                                     
      width: 2rem;                                                                                                                                                                                     
      height: 2rem;                                                                                                                                                                                    
      justify-content: space-around;                                                                                                                                                                   
      cursor: pointer;                                                                                                                                                                                 
      background: none;                                                                                                                                                                                
      border: none;                                                                                                                                                                                    
  }                                                                                                                                                                                                    
                                                                                                                                                                                                       
  .nav-toggle span {                                                                                                                                                                                   
      display: block;                                                                                                                                                                                
      height: 3px;                                                                                                                                                                                     
      width: 100%;                                                                                                                                                                                     
      background-color: var(--primary-500);                                                                                                                                                            
      transition: 0.3s ease;                                                                                                                                                                           
  }     
