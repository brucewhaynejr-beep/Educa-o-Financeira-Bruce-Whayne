          <section class="hero">
              <div class="hero-content">                                                                                                                                                               
                  <h1 class="hero-title">Sobre Nós</h1>                                                                                                                                              
                  <p class="hero-subtitle">Conheça nossa missão de transformar vidas através da educação financeira.</p>                                                                               
              </div>                                                                                                                                                                                   
